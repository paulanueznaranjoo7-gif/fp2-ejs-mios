class Estudiante:
    total_estudiantes = 0
    contador = 1
    estudiantes = []

    def __init__(self, nombre):
        self.__nombre = nombre
        self.__notas = []
        self.__media = 0.0
        self.__codigo_estudiante = f"ES-{Estudiante.contador:03d}"

        Estudiante.contador += 1
        Estudiante.total_estudiantes += 1
        Estudiante.estudiantes.append(self)

    @property
    def codigo_estudiante(self):
        return self.__codigo_estudiante

    @property
    def nombre(self):
        return self.__nombre

    @property
    def media(self):
        return self.__media

    def agregar_nota(self, nota):
        if not (0 <= nota <= 10):
            raise ValueError("Nota fuera del rango permitido")

        self.__notas.append(nota)
        self.__media = sum(self.__notas) / len(self.__notas)

    def aprobado(self):
        return self.__media >= 5

    @classmethod
    def obtener_total_estudiantes(cls):
        return cls.total_estudiantes

    @classmethod
    def mejor_media(cls):
        max_media = -1
        mejor = None

        for alumno in cls.estudiantes:
            if alumno.media > max_media:
                max_media = alumno.media
                mejor = alumno

        return mejor

    def __str__(self):
        return f"{self.__codigo_estudiante} - Nombre: {self.__nombre}, Media: {self.__media}"


# MAIN

e1 = Estudiante("Ana")
e2 = Estudiante("Carlos")
e3 = Estudiante("Lucía")

print("=== Estudiantes creados ===")
print(e1)
print(e2)
print(e3)

print("\n=== Total de estudiantes ===")
print(Estudiante.obtener_total_estudiantes())

print("\n=== Añadiendo notas ===")
e1.agregar_nota(7)
e1.agregar_nota(9)

e2.agregar_nota(4)
e2.agregar_nota(6)

e3.agregar_nota(10)

print(e1)
print(e2)
print(e3)

print("\n=== ¿Están aprobados? ===")
print(e1.nombre, e1.aprobado())
print(e2.nombre, e2.aprobado())
print(e3.nombre, e3.aprobado())

print("\n=== Mejor media ===")
print(Estudiante.mejor_media())

print("\n=== Probando error ===")
try:
    e1.agregar_nota(12)
except ValueError as e:
    print("Error:", e)
