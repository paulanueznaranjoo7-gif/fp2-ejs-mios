class Inventario:

    total_inventarios = [
        ("Central", 3, 4),
        ("Secundario", 2, 5)
    ]

    def __init__(self, nombre, filas, columnas):
        """Inicializa un nuevo inventario."""
        self.filas = filas
        self.columnas = columnas
        self.nombre = nombre
        self.estanterias = []
        for i in range(filas):
            fila = [None] * columnas
            self.estanterias.append(fila)

    def guardar_producto(self, fila, columna, producto):
        if fila > self.filas or columna > self.columnas:
            raise IndexError
        self.estanterias[fila][columna] = producto

    def mover_producto(self, producto, nueva_fila, nueva_columna):
        self.estanterias[nueva_fila][nueva_columna] = producto

    @property
    def productos_guardados(self):
        contador = 0
        for i in range(self.filas):
            for j in range(self.columnas):
                if self.filas < i or self.columnas < j:
                    raise IndexError
                if self.estanterias[i][j] != None:
                    contador += 1
        return contador
                    

    def columna_mas_ocupada(self):
        max_ocupacion = -1
        columna_max = -1
        for j in range(self.columnas):
            contador = 0
            for i in range(self.filas):
                if self.estanterias[i][j] is not None:
                    contador += 1

            if contador > max_ocupacion:
                max_ocupacion = contador
                columna_max = j

        return columna_max

    @classmethod
    def inventarios_registrados(cls):
        return cls.total_inventarios
    


inv = Inventario("Almacen A", 3,4)

inv.guardar_producto(0,1,"Teclado")
inv.guardar_producto(1,2,"Ratón")
inv.guardar_producto(1,3,"Monitor")

print(inv.productos_guardados)

print(inv.columna_mas_ocupada())

inv.mover_producto("Teclado",2,0)

print(Inventario.inventarios_registrados())
