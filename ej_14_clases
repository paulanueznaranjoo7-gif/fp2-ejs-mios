print(LibroBiblioteca.obtener_total_libros())

    # Prestar libros
print("\n=== Prestando libros ===")
libro1.prestar()
libro2.prestar()

print(libro1)
print(libro2)
print(libro3)

print("\n=== Libros prestados ===")
print(LibroBiblioteca.contar_prestados())

# Devolver un libro
